

x# ============================================================
# BACKEND .env  (Vercel)
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit this file. It is for reference only.
# ============================================================

# ── Neon PostgreSQL ───────────────────────────────────────────
# Get this from: console.neon.tech → Your Project → Connection String
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://testitnow_owner:YOURPASSWORD@ep-XXXXX.us-east-2.aws.neon.tech/testitnow?sslmode=require

# ── JWT Auth ──────────────────────────────────────────────────
# Generate a secure random secret: openssl rand -base64 64
JWT_SECRET=your-very-long-random-secret-at-least-64-characters-long
JWT_EXPIRES_IN=7d

# ── CORS — comma-separated list of allowed frontend origins ──
ALLOWED_ORIGINS=https://your-site.netlify.app,http://localhost:3000

# ── Stripe (add when ready for payments) ─────────────────────
# STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# ── Node environment ──────────────────────────────────────────
NODE_ENV=production
