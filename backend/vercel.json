{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "testitnow-backend",
  "installCommand": "npm install",
  "buildCommand": "echo 'Serverless — no build step'",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Cache-Control",           "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/health.js":                          { "maxDuration": 10  },
    "api/v1/auth/[action].js":               { "maxDuration": 30  },
    "api/v1/bugs/[action].js":               { "maxDuration": 30  },
    "api/v1/integrations/[action].js":       { "maxDuration": 30  },
    "api/v1/projects/index.js":              { "maxDuration": 30  },
    "api/v1/reporting/[action].js":          { "maxDuration": 30  },
    "api/v1/engine/[action].js":             { "maxDuration": 60  }
  }
}
