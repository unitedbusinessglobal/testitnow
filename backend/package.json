{
  "name": "testitnow-backend",
  "version": "1.0.0",
  "description": "TestItNow API – Vercel Serverless + Neon PostgreSQL + Stripe",
  "type": "module",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":        "vercel dev",
    "build":      "echo 'Serverless — no build step'",
